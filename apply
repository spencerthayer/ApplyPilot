#!/usr/bin/env bash
clear
printf 'Datetime: %s\n' "$(date '+%Y-%m-%d %H:%M:%S %Z')"
echo "Activating virtual environment..."
echo "> source .venv/bin/activate"
source .venv/bin/activate
echo "Applying with ApplyPilot..."
echo "> applypilot apply $*"
applypilot apply "$@"
rc=$?
if [ "$rc" -eq 0 ]; then
  echo "ApplyPilot application completed."
else
  echo "ApplyPilot application failed (exit code: $rc)."
fi
exit "$rc"
