#!/usr/bin/env bash
clear
printf 'Datetime: %s\n' "$(date '+%Y-%m-%d %H:%M:%S %Z')"
echo "Activating virtual environment..."
echo "> source .venv/bin/activate"
source .venv/bin/activate
echo "Applying with ApplyPilot..."
cmd=(applypilot apply)
default_limit=true
for arg in "$@"; do
  case "$arg" in
    --limit|-l|--limit=*|-l=*|-l[0-9]*)
      default_limit=false
      break
      ;;
  esac
done
if [ "$default_limit" = true ]; then
  cmd+=(--limit 0)
fi
cmd+=("$@")
echo "> ${cmd[*]}"
"${cmd[@]}"
rc=$?
if [ "$rc" -eq 0 ]; then
  echo "ApplyPilot application completed."
else
  echo "ApplyPilot application failed (exit code: $rc)."
fi
exit "$rc"
