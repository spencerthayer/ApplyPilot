#!/usr/bin/env bash
clear
printf 'Datetime: %s\n' "$(date '+%Y-%m-%d %H:%M:%S %Z')"
echo "Activating virtual environment..."
echo "> source .venv/bin/activate"
source .venv/bin/activate
echo "Initializing ApplyPilot..."
echo "> applypilot init"
applypilot init
echo "ApplyPilot initialization completed."