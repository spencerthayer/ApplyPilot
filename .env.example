# ApplyPilot Environment Configuration
# Copy to ~/.applypilot/.env and fill in your values.

# LLM Provider (pick one)
GEMINI_API_KEY=           # Gemini 2.0 Flash (recommended, cheapest)
# OPENAI_API_KEY=         # OpenAI (GPT-4o-mini)
# Local or gateway configuration (OpenAI-compatible endpoints)
# For self-hosted gateways, LiteLLM, Ollama, or AI routers with fallback support.
# Required env vars: LLM_URL, LLM_API_KEY, LLM_MODEL
# Example values (don't use real keys here):
# LLM_URL=https://my-gateway.example.com/v1
# LLM_API_KEY=sk-xxxxx
# LLM_MODEL=gpt-4o-mini
#
# Backend selection for auto-apply and orchestration (APPLY_BACKEND)
# Options: claude (default), opencode (alternative)
# NOTE: Claude Code is the default. Set APPLY_BACKEND=opencode to use OpenCode (requires MCP registration).
APPLY_BACKEND=claude      # claude|opencode  (default: claude)

# Backend-specific defaults for apply command (optional)
APPLY_CLAUDE_MODEL=       # Claude backend default model (default: haiku)
APPLY_OPENCODE_MODEL=     # OpenCode backend default model (fallback: LLM_MODEL or gpt-4o-mini)
APPLY_OPENCODE_AGENT=     # OpenCode --agent value (optional)

# If using an OpenAI-compatible gateway (LiteLLM, Ollama, AI router with fallbacks):
# Use LLM_URL + LLM_API_KEY + LLM_MODEL. ApplyPilot will prefer GEMINI_API_KEY when set.
LLM_URL=                  # e.g. https://my-9router.example.com/v1
LLM_API_KEY=              # API key for the gateway
LLM_MODEL=                # model name the gateway exposes (e.g. gpt-4o-mini)

# OpenCode MCP parity baseline for apply backend:
# Ensure these MCP server names exist in `opencode mcp list` before apply:
#   - playwright
#   - gmail

# Auto-Apply (optional)
CAPSOLVER_API_KEY=        # For CAPTCHA solving during auto-apply

# Proxy (optional, for scraping)
# PROXY=host:port:user:pass
