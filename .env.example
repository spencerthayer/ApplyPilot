# ApplyPilot Environment Configuration
# Copy to ~/.applypilot/.env and fill in your values.

# LLM Provider (pick one)
GEMINI_API_KEY=           # Gemini 2.0 Flash (recommended, cheapest)
# OPENROUTER_API_KEY=     # OpenRouter (default: google/gemini-2.0-flash-001)
# OPENAI_API_KEY=         # OpenAI (GPT-4o-mini)
# ANTHROPIC_API_KEY=      # Anthropic Claude
# LLM_URL=http://127.0.0.1:8080/v1  # Local LLM (llama.cpp, Ollama, gateways)
# LLM_API_KEY=            # Optional key for local/gateway endpoints
# LLM_MODEL=              # Override model name (used for cheap tier: scoring, enrichment)
# LLM_MODEL_MID=          # Mid-tier model (tailoring, cover letters) — falls back to LLM_MODEL
# LLM_MODEL_PREMIUM=      # Premium model (agentic decisions) — falls back to LLM_MODEL_MID

# AWS Bedrock (uses boto3 credential chain — run 'ada credentials update' first)
# BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
# BEDROCK_REGION=us-east-1

# Auto-Apply Agent (optional, separate from the LLM provider above)
AUTO_APPLY_AGENT=auto     # auto prefers Codex CLI, then Claude Code CLI, then OpenCode CLI
AUTO_APPLY_AGENT_PRIORITY=codex,claude,opencode  # fallback order used when AUTO_APPLY_AGENT=auto
# AUTO_APPLY_MODEL=       # Optional browser-agent model override

# Compatibility aliases (optional; AUTO_APPLY_* remains canonical)
# APPLY_BACKEND=opencode
# APPLY_CLAUDE_MODEL=haiku
# APPLY_OPENCODE_MODEL=gpt-4o-mini
# APPLY_OPENCODE_AGENT=applypilot-apply

CAPSOLVER_API_KEY=        # For CAPTCHA solving during auto-apply

# Domain-scoped login credentials (recommended)
# Format: APPLYPILOT_LOGIN_<DOMAIN>_{EMAIL|PASSWORD}
# Example domain transforms:
#   linkedin.com        -> APPLYPILOT_LOGIN_LINKEDIN_COM_*
#   jobs.lever.co       -> APPLYPILOT_LOGIN_JOBS_LEVER_CO_*
#   greenhouse.io       -> APPLYPILOT_LOGIN_GREENHOUSE_IO_*
#   indeed.com          -> APPLYPILOT_LOGIN_INDEED_COM_*
#   ziprecruiter.com    -> APPLYPILOT_LOGIN_ZIPRECRUITER_COM_*
APPLYPILOT_LOGIN_LINKEDIN_COM_EMAIL=
APPLYPILOT_LOGIN_LINKEDIN_COM_PASSWORD=
# APPLYPILOT_LOGIN_INDEED_COM_EMAIL=
# APPLYPILOT_LOGIN_INDEED_COM_PASSWORD=
# APPLYPILOT_LOGIN_ZIPRECRUITER_COM_EMAIL=
# APPLYPILOT_LOGIN_ZIPRECRUITER_COM_PASSWORD=
# APPLYPILOT_LOGIN_GREENHOUSE_IO_EMAIL=
# APPLYPILOT_LOGIN_GREENHOUSE_IO_PASSWORD=
# APPLYPILOT_LOGIN_JOBS_LEVER_CO_EMAIL=
# APPLYPILOT_LOGIN_JOBS_LEVER_CO_PASSWORD=

# Enforce per-domain credentials only (recommended security mode)
APPLYPILOT_REQUIRE_DOMAIN_CREDENTIALS=1

# Legacy fallback (shared password across domains). Keep empty when using domain-scoped creds.
APPLYPILOT_SITE_PASSWORD=

# Proxy (optional, for scraping)
# PROXY=host:port:user:pass
