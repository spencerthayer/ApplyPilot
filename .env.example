# ApplyPilot Environment Configuration
# Copy to ~/.applypilot/.env and fill in your values.

# LLM Provider (pick one)
GEMINI_API_KEY=           # Gemini 2.0 Flash (recommended, cheapest)
# OPENROUTER_API_KEY=     # OpenRouter (default: google/gemini-2.0-flash-001)
# OPENAI_API_KEY=         # OpenAI (GPT-4o-mini)
# LLM_URL=http://127.0.0.1:8080/v1  # Local LLM (llama.cpp, Ollama)
# LLM_MODEL=              # Override model name

# Auto-Apply Agent (optional, separate from the LLM provider above)
AUTO_APPLY_AGENT=auto     # auto prefers Codex CLI, then Claude Code CLI
AUTO_APPLY_AGENT_PRIORITY=codex,claude  # fallback order used when AUTO_APPLY_AGENT=auto
# AUTO_APPLY_MODEL=       # Optional browser-agent model override
CAPSOLVER_API_KEY=        # For CAPTCHA solving during auto-apply

# Proxy (optional, for scraping)
# PROXY=host:port:user:pass
