{
  "work_authorization": {
    "legally_authorized_to_work": "Yes",
    "require_sponsorship": "No",
    "work_permit_type": ""
  },
  "availability": {
    "earliest_start_date": "Immediately",
    "available_for_full_time": "Yes",
    "available_for_contract": "No"
  },
  "compensation": {
    "salary_expectation": "85000",
    "salary_currency": "USD",
    "salary_range_min": "80000",
    "salary_range_max": "100000",
    "currency_conversion_note": ""
  },
  "eeo_voluntary": {
    "gender": "Decline to self-identify",
    "race_ethnicity": "Decline to self-identify",
    "veteran_status": "I am not a protected veteran",
    "disability_status": "I do not wish to answer"
  },
  "tailoring_config": {
    "enabled": true,
    "default_role_type": "software_engineer",
    "validation": {
      "enabled": true,
      "max_retries": 3,
      "min_bullets_per_role": 2,
      "max_bullets_per_role": 5,
      "min_total_bullets_senior": 15,
      "max_total_bullets_senior": 25,
      "min_total_bullets_mid": 12,
      "max_total_bullets_mid": 20,
      "min_total_bullets_junior": 8,
      "max_total_bullets_junior": 15,
      "min_metrics_ratio": 0.7,
      "weak_verbs": [
        "responsible for",
        "assisted with",
        "helped with",
        "worked on",
        "involved in",
        "participated in",
        "contributed to"
      ],
      "metric_patterns": [
        "\\d+%",
        "\\$\\d",
        "\\d+x",
        "\\d+\\s*(?:hours?|days?|weeks?|months?|years?)",
        "\\d+\\s*(?:k|k\\+|million|m|billion|b)?\\s+(?:users?|customers?|requests?|transactions?)"
      ]
    },
    "role_types": {
      "software_engineer": {
        "detection_keywords": ["engineer", "developer", "software", "backend", "frontend"],
        "instructions": {
          "bullet_template": "CAR",
          "max_bullets_per_role": 5
        },
        "constraints": {
          "mechanism_required": true,
          "banned_phrases": ["passionate about", "team player"],
          "required_patterns": ["built", "designed", "implemented"]
        }
      },
      "product_manager": {
        "detection_keywords": ["product manager", "pm", "product owner"],
        "instructions": {
          "bullet_template": "WHO",
          "max_bullets_per_role": 4
        },
        "constraints": {
          "mechanism_required": false,
          "banned_phrases": [],
          "required_patterns": ["launched", "drove", "delivered"]
        }
      }
    },
    "global_rules": {
      "max_summary_lines": 4,
      "selected_impact_metrics": 5,
      "role_compression": {
        "enabled": true,
        "older_than_years": 10,
        "max_bullets_per_old_role": 3
      },
      "formatting": {
        "date_format": "YYYY-MM",
        "bullet_style": "sentence_case",
        "skills_separator": " | "
      }
    },
    "quality_gates": {
      "step_final_assembly": {
        "enabled": true,
        "checks": [
          "check_role_completeness",
          "check_project_completeness",
          "check_bullet_counts",
          "check_total_bullets",
          "check_summary_quality",
          "check_bullet_metrics",
          "check_weak_verbs",
          "check_education_completeness"
        ]
      }
    }
  },
  "files": {
    "profile_photo": "~/.applypilot/files/profile_photo.jpg",
    "portfolio_pdf": "~/.applypilot/files/portfolio_pdf.pdf"
  }
}
